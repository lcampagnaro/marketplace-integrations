# -----------------------------------------------
# Marketplace Integrations - Configuração de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA versione o arquivo .env
# -----------------------------------------------

# Tiny ERP
TINY_TOKEN=seu_token_aqui

# Swagger / Plataforma Soma
SOMA_BEARER_TOKEN=seu_token_aqui
SOMA_BASE_URL=https://api.plataformasoma.com/v1/pedido/

# VNDA
VNDA_BEARER_TOKEN=seu_token_aqui
VNDA_API_URL=https://api.vnda.com.br/api/v2/orders

# Banco de dados
DB_HOST=localhost
DB_NAME=plac
DB_USER=seu_usuario
DB_PASS=sua_senha
